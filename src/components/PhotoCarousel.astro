---

<div class="carousel-wrapper">
	<div class="carousel-track">
		{photos.map((photo) => (
			<img src={`/otherphotos/${photo}`} alt="" loading="lazy" />
		))}
		{/* Duplicate for seamless loop */}
		{photos.map((photo) => (
			<img src={`/otherphotos/${photo}`} alt="" loading="lazy" />
		))}
	</div>
</div>

<style>
	.carousel-wrapper {
		overflow: hidden;
		width: 100vw;
		margin-left: calc(-50vw + 50%);
		padding: 1rem 0;
	}

	.carousel-track {
		display: flex;
		gap: 1rem;
		width: max-content;
		animation: scroll 60s linear infinite;
	}

	.carousel-track:hover {
		animation-play-state: paused;
	}

	.carousel-track img {
		height: 200px;
		width: auto;
		border-radius: 8px;
		object-fit: cover;
		flex-shrink: 0;
	}

	@keyframes scroll {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}
</style>
